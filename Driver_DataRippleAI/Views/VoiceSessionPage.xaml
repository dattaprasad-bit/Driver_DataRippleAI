<UserControl
    x:Class="DataRippleAIDesktop.Views.VoiceSessionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AudioSpectrumAnalyzer="clr-namespace:DataRippleAIDesktop.HelperControls.AudioSpectrumAnalyzer"
    xmlns:HelperControls="clr-namespace:DataRippleAIDesktop.HelperControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DataRippleAIDesktop.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  Style for TabItem headers  -->
        <Style TargetType="TabItem">
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Padding" Value="5,5" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#00D4FF" />

            <!--  Trigger for selected TabItem  -->
            <Style.Triggers>
                <!--  When TabItem is selected  -->
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#00D4FF" />
                    <!--  Selected background color  -->
                    <Setter Property="Foreground" Value="White" />
                    <!--  Selected font color  -->
                    <Setter Property="FontWeight" Value="Bold" />
                    <!--  Bold font weight  -->
                    <Setter Property="TextBlock.TextDecorations" Value="Underline" />
                    <!--  Underline text  -->
                    <Setter Property="BorderBrush" Value="#00D4FF" />
                    <!--  Border color when selected  -->
                    <Setter Property="BorderThickness" Value="2" />
                    <!--  Border thickness when selected  -->
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect
                                BlurRadius="10"
                                Direction="270"
                                Opacity="0.8"
                                ShadowDepth="5"
                                Color="#1DB8B8" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>

                <!--  When TabItem is not selected  -->
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="False">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#00D4FF" />
                    <!--  Default text color  -->
                    <Setter Property="FontWeight" Value="Normal" />
                    <Setter Property="TextBlock.TextDecorations" Value="None" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Effect" Value="{x:Null}" />
                    <!--  Remove glow effect when not selected  -->
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  Style for TabControl to remove extra borders and padding  -->
        <Style TargetType="TabControl">
            <Setter Property="TabStripPlacement" Value="Top" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#132340" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>

        <!--  Style for ScrollViewer  -->
        <Style TargetType="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!--  Style for StackPanel  -->
        <Style TargetType="StackPanel">
            <Setter Property="Orientation" Value="Vertical" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

    </UserControl.Resources>

    <Grid Background="#132340" Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="12"/>
            <!-- Status Bar Row (recording indicator + latency) -->
            <RowDefinition/>
            <!-- Main Content Row (fills available space) -->
            <RowDefinition Height="Auto"/>
            <!-- Progress Bar Row -->
        </Grid.RowDefinitions>


        <!--  Recording Status Indicator  -->
        <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="25,0,0,0" Height="12" Width="35">

            <Ellipse x:Name="recordingIndicator"
                     Width="12"
                     Height="12"
                     Fill="#E74C3C"
                     Margin="0,0,8,0"
                     Visibility="Hidden"/>

            <TextBlock x:Name="recordingPathText"
                       Text=""
                       Foreground="#8B9AAF"
                       FontSize="10"
                       Margin="15,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!--  Audio Streaming Latency Indicator (top-right, visible during active call)  -->
        <Border x:Name="LatencyIndicatorPanel"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,15,0"
                Padding="8,3"
                Background="#1A2942"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="6"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="LatencyStatusDot"
                         Width="7" Height="7"
                         Fill="#27AE60"
                         Margin="0,0,5,0"
                         VerticalAlignment="Center"/>
                <TextBlock Text="Audio Streaming Latency: "
                           Foreground="#8B9AAF"
                           FontSize="10"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="LatencyValueText"
                           Text="-- ms"
                           Foreground="#00D4FF"
                           FontSize="10"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!--  Main Content Panel - Fills available space  -->
        <Border
            x:Name="CallLogPanel"
            Grid.Row="1"
            Margin="5,5,5,5"
            Background="#132340"
            CornerRadius="10"
            BorderBrush="#00D4FF"
            BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#00D4FF" Opacity="0.2"/>
            </Border.Effect>

            <!--  Two-part layout: Top = Customer/Agent cards, Bottom = Call log / Idle panel  -->
            <Grid Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="130"/>
                    <!-- Top half: Customer + Agent voice wave cards -->
                    <RowDefinition Height="*"/>
                    <!-- Bottom half: Call log or idle panel -->
                </Grid.RowDefinitions>

                <!--  ============================================================  -->
                <!--  TOP HALF: Customer Card (left) + Agent Card (right)  -->
                <!--  ============================================================  -->
                <Grid Grid.Row="0" Margin="10,10,10,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!--  Customer Voice Wave Card (Left)  -->
                    <Border Grid.Column="0"
                            Background="#1A2942"
                            BorderBrush="#F59E0B"
                            BorderThickness="1.5"
                            CornerRadius="12"
                            Margin="0,0,6,0"
                            Padding="12,10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#F59E0B" Opacity="0.15"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!--  Customer Header  -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse Width="10" Height="10"
                                         Fill="#F59E0B"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Customer"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#F59E0B"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!--  Customer Voice Wave Visualizer  -->
                            <AudioSpectrumAnalyzer:AudioSpectrumVisualizer
                                x:Name="CustomerAvatarWaveform"
                                Grid.Row="1"
                                Height="60"
                                HorizontalAlignment="Stretch"
                                Foreground="#F59E0B"
                                Visibility="Visible"/>
                        </Grid>
                    </Border>

                    <!--  Center: Active Call Duration Indicator  -->
                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MinWidth="80"
                                Margin="8,0,8,0">

                        <!--  Active Call Indicator (shown only during active call)  -->
                        <StackPanel x:Name="ActiveCallIndicator"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Visibility="Collapsed"
                                    Margin="0,4,0,0">
                            <Ellipse Width="8" Height="8" Fill="#27AE60"
                                     Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1.0" To="0.3"
                                                                 Duration="0:0:1"
                                                                 AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock x:Name="CallDurationText"
                                       Text="00:00" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#00D4FF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!--  Agent Voice Wave Card (Right)  -->
                    <Border Grid.Column="2"
                            Background="#1A2942"
                            BorderBrush="#00D4FF"
                            BorderThickness="1.5"
                            CornerRadius="12"
                            Margin="6,0,0,0"
                            Padding="12,10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#00D4FF" Opacity="0.15"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!--  Agent Header  -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse Width="10" Height="10"
                                         Fill="#00D4FF"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Agent"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#00D4FF"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!--  Agent Voice Wave Visualizer  -->
                            <AudioSpectrumAnalyzer:AudioSpectrumVisualizer
                                x:Name="AgentAvatarWaveform"
                                Grid.Row="1"
                                Height="60"
                                HorizontalAlignment="Stretch"
                                Foreground="#00D4FF"
                                Visibility="Visible"/>
                        </Grid>
                    </Border>
                </Grid>

                <!--  ============================================================  -->
                <!--  BOTTOM HALF: Idle Panel + Call Log (Start/End Call entries)  -->
                <!--  ============================================================  -->

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <!--  Scrollable call log / idle message area  -->
                        <RowDefinition Height="*"/>
                        <!--  Stats cards always pinned at bottom  -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!--  Idle/Welcome State Panel (hidden, kept for code-behind references)  -->
                    <Grid x:Name="IdleWelcomePanel"
                          Grid.Row="0"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Visibility="Collapsed">
                    </Grid>

                    <!--  Call Log Content (scrollable area above stats)  -->
                    <ScrollViewer
                        x:Name="ScrollViewerTranscription"
                        Grid.Row="0"
                        Margin="10,10,10,10"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="StackPanelTranscription" HorizontalAlignment="Stretch">
                            <!--  Call Log content goes here (Start Call, End Call, transcription messages)  -->
                        </StackPanel>
                    </ScrollViewer>

                    <!--  Stats Cards Row (always visible at the bottom)  -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,12">

                        <!--  Total Calls Card  -->
                        <Border Background="#1A2942"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="10"
                                Width="180" Height="80"
                                Margin="0,0,14,0"
                                Padding="10">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="StatsTotalCalls"
                                           Text="0"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#00D4FF"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Total Calls"
                                           FontSize="11"
                                           Foreground="#8B9AAF"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!--  Avg Call Duration Card  -->
                        <Border Background="#1A2942"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="10"
                                Width="180" Height="80"
                                Margin="0,0,14,0"
                                Padding="10">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="StatsAvgDuration"
                                           Text="--:--"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#00D4FF"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Avg Duration"
                                           FontSize="11"
                                           Foreground="#8B9AAF"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!--  Avg Latency Card  -->
                        <Border Background="#1A2942"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="10"
                                Width="180" Height="80"
                                Padding="10">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="StatsAvgLatency"
                                           Text="-- ms"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#00D4FF"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Avg Latency"
                                           FontSize="11"
                                           Foreground="#8B9AAF"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!--  LoaderProgress  -->
        <HelperControls:LoaderProgress
            x:Name="ProgressBarForSummaryGeneration"
            Grid.Row="1"
            Margin="0,49,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Visibility="Collapsed"
            Height="68" Grid.RowSpan="2" Width="184" />

        <!--  Conversation Status Popup -->
        <Popup
            Name="ConversationStatusPopup"
            AllowsTransparency="True"
            IsOpen="False"
            Placement="Center">
            <Border
                Width="400"
                Padding="20"
                Background="#132340"
                BorderBrush="#00D4FF"
                BorderThickness="2"
                CornerRadius="15">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!--  Title  -->
                    <TextBlock
                        Text="Live Conversation Status"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#00D4FF"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15" />

                    <!--  VAD Status Panel  -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <!--  Microphone Status  -->
                        <Border
                            Width="150"
                            Height="80"
                            Background="#1A2942"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="10"
                            Margin="0,0,10,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse
                                    x:Name="MicStatusIndicator"
                                    Width="20"
                                    Height="20"
                                    Fill="#808080"
                                    Margin="0,0,0,5" />
                                <TextBlock
                                    Text="Agent (MIC)"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="#00D4FF"
                                    HorizontalAlignment="Center" />
                                <TextBlock
                                    x:Name="MicStatusText"
                                    Text="Inactive"
                                    FontSize="10"
                                    Foreground="#8B9AAF"
                                    HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!--  Speaker Status  -->
                        <Border
                            Width="150"
                            Height="80"
                            Background="#1A2942"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="10"
                            Margin="10,0,0,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse
                                    x:Name="SpeakerStatusIndicator"
                                    Width="20"
                                    Height="20"
                                    Fill="#808080"
                                    Margin="0,0,0,5" />
                                <TextBlock
                                    Text="Caller (Speaker)"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="#00D4FF"
                                    HorizontalAlignment="Center" />
                                <TextBlock
                                    x:Name="SpeakerStatusText"
                                    Text="Inactive"
                                    FontSize="10"
                                    Foreground="#8B9AAF"
                                    HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!--  Conversation Flow  -->
                    <Border
                        Background="#1A2942"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock
                                Text="Recent Activity"
                                FontSize="12"
                                FontWeight="Bold"
                                Foreground="#C9D1D9"
                                Margin="0,0,0,10" />
                            <ScrollViewer
                                x:Name="ConversationFlowScrollViewer"
                                MaxHeight="120"
                                VerticalScrollBarVisibility="Auto">
                                <StackPanel
                                    x:Name="ConversationFlowPanel"
                                    Orientation="Vertical" />
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!--  Close Button  -->
                    <Button
                        Width="120"
                        Margin="10"
            HorizontalAlignment="Center"
                        Click="CloseConversationStatusPopup_Click"
                        Content="Close">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#00D4FF" />
                                <Setter Property="BorderBrush" Value="#3A4A64" />
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Height" Value="40" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#00B8E6" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="15">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

        <!--  Cloud panel Popup (Custom design)  -->
        <Popup
            Name="CloudPopup"
            AllowsTransparency="True"
            IsOpen="False"
            Placement="Center">
            <Border
                Width="300"
                Padding="20"
                Background="#132340"
                BorderBrush="#00D4FF"
                BorderThickness="2"
                CornerRadius="15">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!--  Scrollable Error message text  -->
                    <ScrollViewer
                        MaxHeight="220"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            Name="PopupText"
                            Width="220"
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center"
                            FontFamily="Microsoft YaHei UI"
                            FontSize="10"
                            FontWeight="Normal"
                            Foreground="#8B9AAF"
                            Text="Error"
                            TextWrapping="Wrap" />
                    </ScrollViewer>

                    <!--  Close Button that calls ClosePopupCommand  -->
                    <Button
                        Width="120"
                        Margin="10"
                        HorizontalAlignment="Center"
                        Click="ClosePopup_Click"
                        Content="Close">
                        <Button.Style>
                            <Style TargetType="Button">
                                <!--  Normal state: background color  -->
                                <Setter Property="Background" Value="#00D4FF" />
                                <Setter Property="BorderBrush" Value="#3A4A64" />
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Height" Value="40" />
                                <!--  Mouse hover state: change background to darker teal  -->
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#00B8E6" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <!--  Apply CornerRadius to Button Template  -->
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="15">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Incoming Call Overlay Panel - Dark Theme -->
        <Border x:Name="IncomingCallPanel"
                Grid.RowSpan="4"
                Background="#132340"
                Visibility="Collapsed"
                Panel.ZIndex="1000">
            <!-- Main Card with Gradient Background -->
            <Border Background="#132340"
                    CornerRadius="20"
                    Width="420"
                    Height="380"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="30,25,30,25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" 
                                    ShadowDepth="0" 
                                    Color="#000000" 
                                    Opacity="0.6"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Incoming Call Header with Phone Icon -->
                    <StackPanel Grid.Row="0"
                               Orientation="Horizontal"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20">
                        <TextBlock Text="📞"
                                   FontSize="24"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="Incoming Call"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Customer Name -->
                    <TextBlock x:Name="IncomingCallCustomerName"
                               Grid.Row="1"
                               Text="John Doe"
                               FontSize="22"
                               FontWeight="Medium"
                               Foreground="#E0E0E0"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <!-- Phone Number -->
                    <TextBlock x:Name="IncomingCallPhoneNumber"
                               Grid.Row="2"
                               Text="+919876543210"
                               FontSize="18"
                               Foreground="#8A9BB8"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0">
                        
                        <!-- Reject Button -->
                        <Button x:Name="RejectCallButton"
                                Width="140"
                                Height="50"
                                Margin="0,0,15,0"
                                Background="#B22222"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="RejectCallButton_Click">
                            <StackPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Center">
                                <TextBlock Text="📞" 
                                          FontSize="18" 
                                          Margin="0,0,8,0"/>
                                <TextBlock Text="Reject" 
                                          FontSize="16"/>
                            </StackPanel>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#B22222"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#8B0000"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#6B0000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Accept Button -->
                        <Button x:Name="AcceptCallButton"
                                Width="140"
                                Height="50"
                                Background="#28A745"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="AcceptCallButton_Click">
                            <StackPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Center">
                                <TextBlock Text="📞" 
                                          FontSize="18" 
                                          Margin="0,0,8,0"/>
                                <TextBlock Text="Accept" 
                                          FontSize="16"/>
                            </StackPanel>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#28A745"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#218838"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1E7E34"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
        
        <!-- Toast Notification for Connection Errors -->
        <Border x:Name="ToastNotification"
                Grid.RowSpan="4"
                Background="#132340"
                BorderBrush="#FF6B6B"
                BorderThickness="2"
                CornerRadius="8"
                Padding="20,15"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,20,0,0"
                Visibility="Collapsed"
                Opacity="0"
                Panel.ZIndex="2000">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="5" Color="#FF6B6B" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="❌" 
                          FontSize="20" 
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"/>
                <TextBlock x:Name="ToastMessage"
                          Text="Connection error" 
                          FontSize="14"
                          FontWeight="SemiBold"
                          Foreground="White"
                          VerticalAlignment="Center"
                          TextWrapping="Wrap"
                          MaxWidth="400"/>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>