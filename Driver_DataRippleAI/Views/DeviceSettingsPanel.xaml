<UserControl x:Class="DataRippleAIDesktop.Views.DeviceSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="#132340">

    <UserControl.Resources>
        <!-- Dark ComboBox Style -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A3A4E"/>
            <Setter Property="Foreground" Value="#C0D0E0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"/>
                                    <ToggleButton Grid.Column="1"
                                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Width="30"
                                                  Cursor="Hand"
                                                  Focusable="False"
                                                  ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path x:Name="Arrow"
                                                          Data="M 0 0 L 6 6 L 12 0"
                                                          Stroke="#6B7A94"
                                                          StrokeThickness="2"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Fill="Transparent"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <!-- Invisible toggle for the entire control -->
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  Opacity="0"/>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide"
                                   Focusable="False">
                                <Border Background="#2A3A4E"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="6"
                                        Margin="0,2,0,0"
                                        MaxHeight="300">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem Style for dark dropdown -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C0D0E0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#354A64"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A3A5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cyan Rounded Button Style -->
        <Style x:Key="CyanButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00D4FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#00B8E6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#0099CC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#3A4A64"/>
                                <Setter Property="Foreground" Value="#6B7A94"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Button Style (X) -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6B7A94"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseBorder" Property="Background" Value="#2A3A4E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Sidebar -->
            <ColumnDefinition x:Name="SidebarColumn" Width="60"/>
            <!-- Main Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border x:Name="InternalSidebar"
                Grid.Column="0"
                Background="#132340"
                BorderBrush="Transparent"
                BorderThickness="0">
            <DockPanel LastChildFill="False">
                <!-- Top Icons -->
                <StackPanel DockPanel.Dock="Top"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0">
                    <!-- DataRipple Logo Icon -->
                    <Border Width="36" Height="36"
                            Background="#132340"
                            CornerRadius="8"
                            Margin="0,0,0,20"
                            Cursor="Hand">
                        <TextBlock Text="D"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#00D4FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Settings Icon (Active) -->
                    <Border Width="36" Height="36"
                            Background="#1A2942"
                            CornerRadius="8"
                            Margin="0,0,0,16"
                            Cursor="Hand">
                        <Viewbox Width="20" Height="20">
                            <Canvas Width="24" Height="24">
                                <Path Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"
                                      Fill="#00D4FF"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!-- Microphone Icon with orange badge -->
                    <Grid Width="36" Height="36"
                          Margin="0,0,0,16"
                          Cursor="Hand">
                        <Border Background="Transparent"
                                CornerRadius="8">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12,14c1.66,0,2.99-1.34,2.99-3L15,5c0-1.66-1.34-3-3-3S9,3.34,9,5v6C9,12.66,10.34,14,12,14z M17.3,11 c0,3-2.54,5.1-5.3,5.1S6.7,14,6.7,11H5c0,3.42,2.72,6.23,6,6.72V21h2v-3.28c3.28-0.48,6-3.3,6-6.72H17.3z"
                                          Fill="#6B7A94"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <!-- Orange notification badge -->
                        <Border x:Name="MicBadge"
                                Width="10" Height="10"
                                Background="#FFA500"
                                CornerRadius="5"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,2,4,0"
                                Visibility="Collapsed"/>
                    </Grid>
                </StackPanel>

                <!-- Bottom Icons -->
                <StackPanel DockPanel.Dock="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                    <!-- Logout/Disconnect Icon -->
                    <Border Width="36" Height="36"
                            Background="Transparent"
                            CornerRadius="8"
                            Cursor="Hand"
                            MouseLeftButtonUp="CloseButton_Click">
                        <Viewbox Width="20" Height="20">
                            <Canvas Width="24" Height="24">
                                <Path Data="M10.09,15.59L11.5,17l5-5l-5-5l-1.41,1.41L12.67,11H3v2h9.67L10.09,15.59z M19,3H5C3.89,3,3,3.9,3,5v4h2V5h14v14H5v-4H3v4 c0,1.1,0.89,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.1,3,19,3z"
                                      Fill="#6B7A94"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Content -->
                <RowDefinition Height="*"/>
                <!-- Bottom Status Bar -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Title + Close Button -->
            <Border x:Name="InternalHeader"
                    Grid.Row="0"
                    Background="#132340"
                    Padding="28,20,28,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Devices"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="X"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Device Settings Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#132340">
                <StackPanel Margin="28,10,28,20">

                    <!-- Microphone Section -->
                    <StackPanel Margin="0,0,0,28">
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12,14c1.66,0,2.99-1.34,2.99-3L15,5c0-1.66-1.34-3-3-3S9,3.34,9,5v6C9,12.66,10.34,14,12,14z M17.3,11 c0,3-2.54,5.1-5.3,5.1S6.7,14,6.7,11H5c0,3.42,2.72,6.23,6,6.72V21h2v-3.28c3.28-0.48,6-3.3,6-6.72H17.3z"
                                          Fill="#00D4FF"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Microphone"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#00D4FF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Dropdown + Test Button Row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="MicrophoneCombo"
                                      Grid.Column="0"
                                      Style="{StaticResource DarkComboBoxStyle}"
                                      SelectionChanged="MicrophoneCombo_SelectionChanged"
                                      Margin="0,0,10,0"/>

                            <Button x:Name="TestMicButton"
                                    Grid.Column="1"
                                    Content="Test"
                                    Style="{StaticResource CyanButtonStyle}"
                                    MinWidth="70"
                                    Height="42"
                                    Click="TestMicButton_Click"/>
                        </Grid>

                        <!-- Mic Warning Message -->
                        <StackPanel x:Name="MicWarningPanel"
                                    Orientation="Horizontal"
                                    Margin="0,4,0,0"
                                    Visibility="Collapsed">
                            <TextBlock Text="&#x26A0;"
                                       FontSize="13"
                                       Foreground="#FFA500"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="MicWarningText"
                                       Text="Microphone has no audio"
                                       FontSize="13"
                                       Foreground="#FFA500"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Mic Test Status (shown after test) -->
                        <TextBlock x:Name="MicTestStatus"
                                   Text=""
                                   FontSize="12"
                                   Foreground="#6B7A94"
                                   Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Speakers Section -->
                    <StackPanel Margin="0,0,0,20">
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12,1c-4.97,0-9,4.03-9,9v7c0,1.66,1.34,3,3,3h3v-8H5v-2c0-3.87,3.13-7,7-7s7,3.13,7,7v2h-4v8h3c1.66,0,3-1.34,3-3v-7 C21,5.03,16.97,1,12,1z"
                                          Fill="#00D4FF"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Speakers"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#00D4FF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Dropdown + Test Button Row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="SpeakerCombo"
                                      Grid.Column="0"
                                      Style="{StaticResource DarkComboBoxStyle}"
                                      SelectionChanged="SpeakerCombo_SelectionChanged"
                                      Margin="0,0,10,0"/>

                            <Button x:Name="TestSpeakerButton"
                                    Grid.Column="1"
                                    Content="Test"
                                    Style="{StaticResource CyanButtonStyle}"
                                    MinWidth="70"
                                    Height="42"
                                    Click="TestSpeakerButton_Click"/>
                        </Grid>

                        <!-- Speaker Test Status -->
                        <TextBlock x:Name="SpeakerTestStatus"
                                   Text=""
                                   FontSize="12"
                                   Foreground="#6B7A94"
                                   Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Status Bar -->
            <Border x:Name="InternalStatusBar"
                    Grid.Row="2"
                    Background="#132340"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Connection Status -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="ConnectionDot"
                                 Width="8" Height="8"
                                 Fill="#28A745"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="ConnectionStatusText"
                                   Text="Connected"
                                   FontSize="12"
                                   Foreground="#8B9AAF"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: Latency + Signal Bars -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="LatencyText"
                                   Text="Latency: --"
                                   FontSize="12"
                                   Foreground="#8B9AAF"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <!-- Signal strength bars -->
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,0">
                            <Border x:Name="SignalBar1" Width="3" Height="6" Background="#28A745" CornerRadius="1" Margin="1,0" VerticalAlignment="Bottom"/>
                            <Border x:Name="SignalBar2" Width="3" Height="10" Background="#28A745" CornerRadius="1" Margin="1,0" VerticalAlignment="Bottom"/>
                            <Border x:Name="SignalBar3" Width="3" Height="14" Background="#28A745" CornerRadius="1" Margin="1,0" VerticalAlignment="Bottom"/>
                            <Border x:Name="SignalBar4" Width="3" Height="18" Background="#28A745" CornerRadius="1" Margin="1,0" VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
