<Window
    x:Class="DataRippleAIDesktop.Views.ActiveCallPopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ShowInTaskbar="False"
    ShowActivated="False"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Circular icon button style (mute, end call, expand) -->
        <Style x:Key="CircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- End call / Reject button style (red) -->
        <Style x:Key="EndCallButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleButtonStyle}">
            <Setter Property="Background" Value="#E53935"/>
            <Setter Property="ToolTip" Value="End Call"/>
        </Style>

        <!-- Accept call button style (green) -->
        <Style x:Key="AcceptCallButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleButtonStyle}">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="ToolTip" Value="Accept Call"/>
        </Style>

        <!-- Mute button style (dark) -->
        <Style x:Key="MuteButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleButtonStyle}">
            <Setter Property="Background" Value="#1A3A5C"/>
            <Setter Property="ToolTip" Value="Toggle Mute"/>
        </Style>

        <!-- Expand button style (dark) -->
        <Style x:Key="ExpandButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleButtonStyle}">
            <Setter Property="Background" Value="#1A3A5C"/>
            <Setter Property="ToolTip" Value="Expand to Main Window"/>
        </Style>
    </Window.Resources>

    <!-- Main card -->
    <Border x:Name="PopupBorder"
            Background="#132340"
            BorderBrush="#1A3A5C"
            BorderThickness="1"
            CornerRadius="12"
            Width="320"
            Padding="16,12,16,12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="4"
                              Color="#000000"
                              Opacity="0.6"
                              Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Row 0: Header -->
                <RowDefinition Height="Auto"/>  <!-- Row 1: Caller info -->
                <RowDefinition Height="Auto"/>  <!-- Row 2: Action buttons -->
            </Grid.RowDefinitions>

            <!-- ============================================================= -->
            <!-- Row 0: Header - Two overlapping panels for Ringing vs Active  -->
            <!-- ============================================================= -->

            <!-- RINGING header: pulsing orange dot + "Incoming Call" + "Ringing..." -->
            <Grid x:Name="RingingHeaderPanel" Grid.Row="0" Margin="0,0,0,10" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Orange dot -->
                    <ColumnDefinition Width="Auto"/>  <!-- "Incoming Call" text -->
                    <ColumnDefinition Width="*"/>     <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>  <!-- "Ringing..." text -->
                </Grid.ColumnDefinitions>

                <!-- Pulsing orange dot -->
                <Ellipse x:Name="RingingDot"
                         Grid.Column="0"
                         Width="10" Height="10"
                         Fill="#FF9800"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1.0" To="0.2"
                                                     Duration="0:0:0.6"
                                                     AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <TextBlock Grid.Column="1"
                           Text="Incoming Call"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#FF9800"
                           VerticalAlignment="Center"/>

                <!-- "Ringing..." text with pulsing animation -->
                <TextBlock x:Name="RingingStatusText"
                           Grid.Column="3"
                           Text="Ringing..."
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#FF9800"
                           VerticalAlignment="Center">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1.0" To="0.4"
                                                     Duration="0:0:0.8"
                                                     AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </Grid>

            <!-- ACTIVE CALL header: pulsing green dot + "Active Call" + duration -->
            <Grid x:Name="ActiveCallHeaderPanel" Grid.Row="0" Margin="0,0,0,10" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Green dot -->
                    <ColumnDefinition Width="Auto"/>  <!-- "Active Call" text -->
                    <ColumnDefinition Width="*"/>     <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>  <!-- Duration -->
                </Grid.ColumnDefinitions>

                <!-- Pulsing green dot -->
                <Ellipse Grid.Column="0"
                         Width="10" Height="10"
                         Fill="#27AE60"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1.0" To="0.3"
                                                     Duration="0:0:1"
                                                     AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <TextBlock Grid.Column="1"
                           Text="Active Call"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#6B8AAD"
                           VerticalAlignment="Center"/>

                <!-- Call duration -->
                <TextBlock x:Name="CallDurationText"
                           Grid.Column="3"
                           Text="00:00"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#00D4FF"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Row 1: Caller info (name + phone number) -->
            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock x:Name="CallerNameText"
                           Text="Unknown"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="288"/>
                <TextBlock x:Name="PhoneNumberText"
                           Text=""
                           FontSize="12"
                           Foreground="#6B8AAD"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="288"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- ============================================================= -->
            <!-- Row 2: Action buttons - Two panels for Ringing vs Active      -->
            <!-- ============================================================= -->

            <!-- RINGING buttons: Accept (green), Reject (red), Expand -->
            <StackPanel x:Name="RingingButtonsPanel"
                        Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed">

                <!-- Accept Call button (green) -->
                <Button x:Name="AcceptCallButton"
                        Style="{StaticResource AcceptCallButtonStyle}"
                        Click="AcceptCallButton_Click"
                        Margin="0,0,12,0"
                        ToolTip="Accept Call">
                    <!-- Phone pickup icon -->
                    <TextBlock Text="&#x2713;"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Reject Call button (red) -->
                <Button x:Name="RejectCallButton"
                        Style="{StaticResource EndCallButtonStyle}"
                        Click="RejectCallButton_Click"
                        Margin="0,0,12,0"
                        ToolTip="Reject Call">
                    <!-- X icon for reject -->
                    <TextBlock Text="&#x2717;"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Expand / Restore to main window button -->
                <Button x:Name="RingingExpandButton"
                        Style="{StaticResource ExpandButtonStyle}"
                        Click="ExpandButton_Click">
                    <!-- Expand icon -->
                    <TextBlock Text="&#x1F5D6;"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </StackPanel>

            <!-- ACTIVE CALL buttons: Mute, End Call, Expand -->
            <StackPanel x:Name="ActiveCallButtonsPanel"
                        Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Visibility="Visible">

                <!-- Mute / Unmute button -->
                <Button x:Name="MuteButton"
                        Style="{StaticResource MuteButtonStyle}"
                        Click="MuteButton_Click"
                        Margin="0,0,12,0">
                    <!-- Microphone icon (Unicode) -->
                    <TextBlock x:Name="MuteIcon"
                               Text="&#x1F399;"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- End Call button -->
                <Button x:Name="EndCallButton"
                        Style="{StaticResource EndCallButtonStyle}"
                        Click="EndCallButton_Click"
                        Margin="0,0,12,0">
                    <!-- Phone hangup icon -->
                    <TextBlock Text="&#x1F4F5;"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Expand / Restore to main window button -->
                <Button x:Name="ExpandButton"
                        Style="{StaticResource ExpandButtonStyle}"
                        Click="ExpandButton_Click">
                    <!-- Expand icon (Unicode box with arrow) -->
                    <TextBlock Text="&#x1F5D6;"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
