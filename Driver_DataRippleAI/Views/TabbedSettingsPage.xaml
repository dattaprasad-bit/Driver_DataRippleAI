<UserControl x:Class="DataRippleAIDesktop.Views.TabbedSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="#132340">

    <UserControl.Resources>
        <!-- Dark ComboBox Style -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A3A4E"/>
            <Setter Property="Foreground" Value="#C0D0E0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"/>
                                    <ToggleButton Grid.Column="1"
                                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Width="30"
                                                  Cursor="Hand"
                                                  Focusable="False"
                                                  ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path x:Name="Arrow"
                                                          Data="M 0 0 L 6 6 L 12 0"
                                                          Stroke="#6B7A94"
                                                          StrokeThickness="2"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Fill="Transparent"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <!-- Invisible toggle for the entire control -->
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  Opacity="0"/>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide"
                                   Focusable="False">
                                <Border Background="#2A3A4E"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="6"
                                        Margin="0,2,0,0"
                                        MaxHeight="300">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem Style for dark dropdown -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C0D0E0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#354A64"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A3A5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cyan Rounded Button Style -->
        <Style x:Key="CyanButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00D4FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#00B8E6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#0099CC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#3A4A64"/>
                                <Setter Property="Foreground" Value="#6B7A94"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header with title and close -->
            <RowDefinition Height="Auto" />
            <!-- Main content -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header spacer (Back button moved to MainWindow title bar) -->
        <Border Grid.Row="0"
                Background="#132340"
                Padding="28,10,28,0" />

        <!-- Main Scrollable Content (no tabs) - Border matching VoiceSessionPage CallLogPanel -->
        <Border Grid.Row="1"
                Margin="15,5,15,15"
                Background="#132340"
                CornerRadius="12"
                BorderBrush="#00D4FF"
                BorderThickness="1"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#00D4FF" Opacity="0.15"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="28,20,28,20">

                    <!-- ====== Server Connection Settings Section ====== -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Viewbox Width="20" Height="20" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12,1L3,5v6c0,5.55,3.84,10.74,9,12c5.16-1.26,9-6.45,9-12V5L12,1z M12,11.99h7c-0.53,4.12-3.28,7.79-7,8.94V12H5V6.3l7-3.11V11.99z"
                                      Fill="#00D4FF" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Server Connection Settings"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#00D4FF"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- API URL -->
                    <TextBlock Text="API URL"
                               FontSize="13"
                               Foreground="#8B9AAF"
                               Margin="0,0,0,6" />
                    <Border Background="#2A3A4E"
                            CornerRadius="20"
                            Height="42"
                            Margin="0,0,0,16">
                        <TextBox x:Name="ApiUrlBox"
                                 Text=""
                                 FontSize="13"
                                 Foreground="#C0D0E0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="16,0"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="White"
                                 LostFocus="ApiUrlBox_LostFocus" />
                    </Border>

                    <!-- Username -->
                    <TextBlock Text="Username"
                               FontSize="13"
                               Foreground="#8B9AAF"
                               Margin="0,0,0,6" />
                    <Border Background="#2A3A4E"
                            CornerRadius="20"
                            Height="42"
                            Margin="0,0,0,24">
                        <TextBox x:Name="UsernameBox"
                                 Text=""
                                 FontSize="13"
                                 Foreground="#C0D0E0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="16,0"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="White"
                                 IsReadOnly="True" />
                    </Border>

                    <!-- Separator before Devices -->
                    <Border Height="1"
                            Background="#2A3A4E"
                            Margin="0,24,0,24" />

                    <!-- ====== Devices Sub-Section ====== -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <!-- Headset/Speaker icon for Devices -->
                        <Viewbox Width="20" Height="20" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12,1c-4.97,0-9,4.03-9,9v7c0,1.66,1.34,3,3,3h3v-8H5v-2c0-3.87,3.13-7,7-7s7,3.13,7,7v2h-4v8h3c1.66,0,3-1.34,3-3v-7C21,5.03,16.97,1,12,1z"
                                      Fill="#00D4FF" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Devices"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#00D4FF"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Microphone and Speakers side by side -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Microphone Column -->
                        <StackPanel Grid.Column="0">
                            <!-- Microphone Label -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12,14c1.66,0,2.99-1.34,2.99-3L15,5c0-1.66-1.34-3-3-3S9,3.34,9,5v6C9,12.66,10.34,14,12,14z M17.3,11c0,3-2.54,5.1-5.3,5.1S6.7,14,6.7,11H5c0,3.42,2.72,6.23,6,6.72V21h2v-3.28c3.28-0.48,6-3.3,6-6.72H17.3z"
                                              Fill="#8B9AAF" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Microphone"
                                           FontSize="13"
                                           Foreground="#8B9AAF"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Microphone Dropdown + Test Button -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="MicrophoneCombo"
                                          Grid.Column="0"
                                          Style="{StaticResource DarkComboBoxStyle}"
                                          SelectionChanged="MicrophoneCombo_SelectionChanged"
                                          Margin="0,0,8,0" />

                                <Button x:Name="TestMicButton"
                                        Grid.Column="1"
                                        Content="Test"
                                        Style="{StaticResource CyanButtonStyle}"
                                        MinWidth="64"
                                        Height="42"
                                        Click="TestMicButton_Click" />
                            </Grid>

                            <!-- Mic Warning -->
                            <StackPanel x:Name="MicWarningPanel"
                                        Orientation="Horizontal"
                                        Margin="0,4,0,0"
                                        Visibility="Collapsed">
                                <TextBlock Text="&#x26A0;"
                                           FontSize="13"
                                           Foreground="#FFA500"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="MicWarningText"
                                           Text="Microphone has no audio"
                                           FontSize="13"
                                           Foreground="#FFA500"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Mic Test Status -->
                            <TextBlock x:Name="MicTestStatus"
                                       Text=""
                                       FontSize="12"
                                       Foreground="#6B7A94"
                                       Margin="0,4,0,0"
                                       Visibility="Collapsed" />
                        </StackPanel>

                        <!-- Speakers Column -->
                        <StackPanel Grid.Column="2">
                            <!-- Speakers Label -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M3,9v6h4l5,5V4L7,9H3z M16.5,12c0-1.77-1.02-3.29-2.5-4.03v8.05C15.48,15.29,16.5,13.77,16.5,12z M14,3.23v2.06c2.89,0.86,5,3.54,5,6.71s-2.11,5.85-5,6.71v2.06c4.01-0.91,7-4.49,7-8.77S18.01,4.14,14,3.23z"
                                              Fill="#8B9AAF" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Speakers"
                                           FontSize="13"
                                           Foreground="#8B9AAF"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Speaker Dropdown + Test Button -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="SpeakerCombo"
                                          Grid.Column="0"
                                          Style="{StaticResource DarkComboBoxStyle}"
                                          SelectionChanged="SpeakerCombo_SelectionChanged"
                                          Margin="0,0,8,0" />

                                <Button x:Name="TestSpeakerButton"
                                        Grid.Column="1"
                                        Content="Test"
                                        Style="{StaticResource CyanButtonStyle}"
                                        MinWidth="64"
                                        Height="42"
                                        Click="TestSpeakerButton_Click" />
                            </Grid>

                            <!-- Speaker Test Status -->
                            <TextBlock x:Name="SpeakerTestStatus"
                                       Text=""
                                       FontSize="12"
                                       Foreground="#6B7A94"
                                       Margin="0,4,0,0"
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>

                    <!-- Separator before Access Logs -->
                    <Border Height="1"
                            Background="#2A3A4E"
                            Margin="0,24,0,24" />

                    <!-- ====== Access Logs Section ====== -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12,6c1.93,0,3.5,1.57,3.5,3.5S13.93,13,12,13 s-3.5-1.57-3.5-3.5S10.07,6,12,6z M12,20c-2.03,0-4.43-0.82-6.14-2.88C7.55,15.8,9.68,15,12,15s4.45,0.8,6.14,2.12 C16.43,19.18,14.03,20,12,20z"
                                      Fill="#00D4FF" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Access Logs"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#00D4FF"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Access Logs Display Area -->
                    <Border Background="#132340"
                            CornerRadius="8"
                            Padding="16,12"
                            MinHeight="150"
                            Margin="0,0,0,10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      MaxHeight="200">
                            <TextBlock x:Name="AccessLogsText"
                                       Text="No access logs available."
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="#8B9AAF"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
