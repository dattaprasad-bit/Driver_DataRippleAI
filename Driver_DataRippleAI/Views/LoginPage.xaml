<UserControl
    x:Class="DataRippleAIDesktop.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Background="#132340">

    <Grid>
        <!-- Logo at top left (hidden) -->
        <Image Source="pack://application:,,,/logo-full.png"
               Width="180"
               Height="50"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="40,30,0,0"
               Stretch="Uniform"
               Visibility="Collapsed" />

        <!-- Main Login Container -->
        <Border
            Width="470"
            Height="Auto"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadius="12"
            Padding="50,40"
            Margin="0,-60,0,0"
            BorderBrush="#2A3A52"
            BorderThickness="1">
            <Border.Background>
                <SolidColorBrush Color="#132340" Opacity="0.6"/>
            </Border.Background>

            <StackPanel>
                <!-- Login Title -->
                <TextBlock 
                    Text="Login"
                    FontSize="32"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Margin="0,0,0,8" />

                <!-- Description -->
                <TextBlock 
                    Text="Please enter your user id &amp; password below"
                    FontSize="14"
                    Foreground="#8B9AAF"
                    Margin="0,0,0,32" />

                <!-- User Info Panel (shown when logged in) -->
                <Border
                    x:Name="UserInfoPanel"
                    Background="#132340"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="12"
                    Padding="20"
                    Visibility="Collapsed"
                    Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock
                            Text="✅ Already Logged In"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#81C784"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,10" />
                        <TextBlock
                            x:Name="txtUserName"
                            FontSize="14"
                            Foreground="#C9D1D9"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,5" />
                        <TextBlock
                            x:Name="txtUserEmail"
                            FontSize="12"
                            Foreground="#7D8590"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,15" />
                        <Button
                            x:Name="btnContinue"
                            Height="45"
                            Click="btnContinue_Click"
                            Background="#81C784"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,10">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#66BB6A" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="🚀" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="Continue to App" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="btnLogout"
                            Height="40"
                            Click="btnLogout_Click"
                            Background="#B22222"
                            BorderThickness="0"
                            Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#8B0000" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="🚪" FontSize="12" Margin="0,0,6,0" />
                                <TextBlock Text="Logout" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Email Input -->
                <StackPanel x:Name="EmailPanel">
                    <TextBlock
                        x:Name="lblEmail"
                        Text="Email"
                        FontSize="14"
                        Foreground="White"
                        Margin="0,0,0,8" />

                    <Border x:Name="borderEmail" 
                            Background="#1A2942" 
                            CornerRadius="6" 
                            Height="48"
                            BorderThickness="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                      Text="👤"
                                      FontSize="16"
                                      Foreground="#6B7A94"
                                      VerticalAlignment="Center"
                                      Margin="16,0,12,0" />

                            <TextBox
                                x:Name="txtEmail"
                                Grid.Column="1"
                                FontSize="14"
                                Padding="0,0,16,0"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#8B9AAF"
                                CaretBrush="White"
                                VerticalAlignment="Center"
                                Text="abc@xyx.com">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <EventSetter Event="GotFocus" Handler="txtEmail_GotFocus"/>
                                        <EventSetter Event="LostFocus" Handler="txtEmail_LostFocus"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>
                    
                    <!-- Email Error Message -->
                    <TextBlock
                        x:Name="txtEmailError"
                        FontSize="12"
                        Foreground="#FF6B6B"
                        Margin="0,4,0,0"
                        TextWrapping="Wrap"
                        Visibility="Collapsed" />
                </StackPanel>

                <!-- Password Input -->
                <StackPanel x:Name="PasswordPanel" Margin="0,20,0,0">
                    <TextBlock
                        x:Name="lblPassword"
                        Text="Password"
                        FontSize="14"
                        Foreground="White"
                        Margin="0,0,0,8" />

                    <Border x:Name="borderPassword"
                            Background="#1A2942" 
                            CornerRadius="6" 
                            Height="48"
                            BorderThickness="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                      Text="🔒"
                                      FontSize="16"
                                      Foreground="#6B7A94"
                                      VerticalAlignment="Center"
                                      Margin="16,0,12,0" />

                            <PasswordBox
                                x:Name="pwdPassword"
                                Grid.Column="1"
                                FontSize="14"
                                Padding="0,0,8,0"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#8B9AAF"
                                CaretBrush="White"
                                VerticalAlignment="Center">
                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="PasswordBox">
                                                    <ScrollViewer x:Name="PART_ContentHost" 
                                                                VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </PasswordBox.Style>
                            </PasswordBox>

                            <TextBox
                                x:Name="txtPasswordVisible"
                                Grid.Column="1"
                                FontSize="14"
                                Padding="0,0,8,0"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#8B9AAF"
                                CaretBrush="White"
                                VerticalAlignment="Center"
                                Visibility="Collapsed" />

                            <Button
                                x:Name="btnTogglePassword"
                                Grid.Column="2"
                                Width="45"
                                Height="48"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="btnTogglePassword_Click"
                                Cursor="Hand">
                                <TextBlock Text="👁" FontSize="16" Foreground="#6B7A94" />
                            </Button>
                        </Grid>
                    </Border>
                    
                    <!-- Password Error Message -->
                    <TextBlock
                        x:Name="txtPasswordError"
                        FontSize="12"
                        Foreground="#FF6B6B"
                        Margin="0,4,0,0"
                        TextWrapping="Wrap"
                        Visibility="Collapsed" />
                </StackPanel>

                <!-- Remember Me and Dev Mode Checkboxes -->
                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <CheckBox x:Name="chkRememberMe"
                              Content="Remember me"
                              Foreground="#8B9AAF"
                              FontSize="14"
                              VerticalAlignment="Center"
                              Checked="chkRememberMe_Checked"
                              Unchecked="chkRememberMe_Unchecked">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="Border"
                                                        Width="18"
                                                        Height="18"
                                                        Background="#1A2942"
                                                        BorderBrush="#3A4A64"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        VerticalAlignment="Center">
                                                    <TextBlock x:Name="CheckMark"
                                                             Text="&#x2713;"
                                                             FontSize="12"
                                                             FontWeight="Bold"
                                                             Foreground="#1DB8B8"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                                </Border>
                                                <ContentPresenter Margin="8,0,0,0"
                                                                VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="Border" Property="Background" Value="#1A2942"/>
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#1DB8B8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <CheckBox x:Name="chkDevMode"
                              Content="Dev Mode"
                              Foreground="#8B9AAF"
                              FontSize="14"
                              IsChecked="False"
                              VerticalAlignment="Center"
                              Margin="24,0,0,0">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="Border"
                                                        Width="18"
                                                        Height="18"
                                                        Background="#1A2942"
                                                        BorderBrush="#3A4A64"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        VerticalAlignment="Center">
                                                    <TextBlock x:Name="CheckMark"
                                                             Text="&#x2713;"
                                                             FontSize="12"
                                                             FontWeight="Bold"
                                                             Foreground="#E6A817"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                                </Border>
                                                <ContentPresenter Margin="8,0,0,0"
                                                                VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="Border" Property="Background" Value="#1A2942"/>
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#E6A817"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>
                </StackPanel>

                <!-- Client Sign In Button -->
                <Button
                    x:Name="btnClientSignIn"
                    Height="50"
                    Click="btnClientSignIn_Click"
                    Background="#1DB8B8"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,24,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#19A8A8" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#159898" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock
                        Text="Login"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </Button>

                <!-- Skip Login Button (Temporary) -->
                <Button
                    x:Name="btnSkipLogin"
                    Height="45"
                    Click="btnSkipLogin_Click"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,12,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A2942" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0" />
                        <TextBlock Text="Skip Login (Temp)" FontSize="14" Foreground="#8B9AAF" />
                    </StackPanel>
                </Button>

                <!-- Loading Indicator -->
                <StackPanel
                    x:Name="LoadingPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0"
                    Visibility="Collapsed">
                    <TextBlock Text="⏳" FontSize="16" Margin="0,0,10,0" />
                    <TextBlock Text="Signing in..." FontSize="14" Foreground="#8B9AAF" />
                </StackPanel>

                <!-- Error Message -->
                <Border
                    x:Name="ErrorBorder"
                    Background="#2A1F1F"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,16,0,0"
                    Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100">
                        <TextBlock
                            x:Name="txtErrorMessage"
                            FontSize="12"
                            Foreground="#FF6B6B"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>

                <!-- Status Message -->
                <Border
                    x:Name="StatusBorder"
                    Background="#132340"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,16,0,0"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="txtStatusMessage"
                        FontSize="12"
                        Foreground="#81C784"
                        HorizontalAlignment="Center"
                        TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Grid VerticalAlignment="Bottom" Margin="40,0,40,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                      Text="© 2026 Dataripple.ai — All rights reserved."
                      FontSize="12"
                      Foreground="#5A6A84"
                      VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="Terms of service" 
                          FontSize="12"
                          Foreground="#5A6A84"
                          Cursor="Hand"
                          Margin="0,0,20,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#8B9AAF" />
                                    <Setter Property="TextDecorations" Value="Underline" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="Privacy Policy" 
                          FontSize="12"
                          Foreground="#5A6A84"
                          Cursor="Hand">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#8B9AAF" />
                                    <Setter Property="TextDecorations" Value="Underline" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- WebView2 Overlay for Client Authentication -->
        <Border
            x:Name="WebViewOverlay"
            Background="#CC000000"
            Visibility="Collapsed">

            <Border
                Width="900"
                Height="600"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#132340"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#132340" Padding="15,10">
                        <Grid>
                            <TextBlock
                                Text="Client Authentication"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="White"
                                VerticalAlignment="Center" />

                            <Button
                                x:Name="btnCloseWebView"
                                HorizontalAlignment="Right"
                                Width="30"
                                Height="30"
                                Background="Transparent"
                                BorderThickness="0"
                                Content="✕"
                                FontSize="16"
                                Foreground="White"
                                Click="btnCloseWebView_Click"
                                Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1A2942" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <wv2:WebView2
                        x:Name="clientWebView"
                        Grid.Row="1"
                        Margin="5"
                        NavigationCompleted="ClientWebView_NavigationCompleted" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>