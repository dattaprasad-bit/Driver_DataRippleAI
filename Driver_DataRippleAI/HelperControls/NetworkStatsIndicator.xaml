<UserControl x:Class="DataRippleAIDesktop.HelperControls.NetworkStatsIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="300">
    <Border Background="#1A2942"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="8"
            Padding="12,8"
            Cursor="Hand"
            ToolTip="Network Statistics: Connection Status, Latency, Network Speed">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Connection Status Indicator -->
            <Ellipse x:Name="StatusIndicator"
                     Grid.Column="0"
                     Width="10"
                     Height="10"
                     Margin="0,0,10,0"
                     VerticalAlignment="Center">
                <Ellipse.Fill>
                    <SolidColorBrush x:Name="StatusBrush" Color="#FF6B6B"/>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Stats Display -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Connection Status -->
                <TextBlock x:Name="txtConnectionStatus"
                           Text="Disconnected"
                           FontSize="11"
                           Foreground="#B0B0B0"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           ToolTip="Internet connection status"/>

                <!-- Backend WS Status (managed by MainWindow via UpdateBackendWsStatus) -->
                <StackPanel x:Name="BackendWsSection"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0"
                            Visibility="Collapsed"
                            ToolTip="Backend API Reachability">
                    <TextBlock Text="BE WS:"
                               Foreground="#8B9AAF"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0" />
                    <Ellipse x:Name="BackendWsIndicator"
                             Width="10" Height="10"
                             Fill="#808080"
                             Stroke="#5A6A84"
                             StrokeThickness="1"
                             VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="3"
                                              ShadowDepth="0"
                                              Color="#808080"
                                              Opacity="0.5" />
                        </Ellipse.Effect>
                    </Ellipse>
                </StackPanel>

                <!-- Separator between BE WS and Latency -->
                <Rectangle x:Name="BackendWsSeparator"
                           Width="1" Height="14"
                           Fill="#2A3A52"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />

                <!-- Latency -->
                <TextBlock x:Name="txtLatency"
                           Text="Latency: N/A"
                           FontSize="11"
                           Foreground="#B0B0B0"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           ToolTip="Internet latency (ping to 8.8.8.8)"/>

                <!-- Network Speed -->
                <TextBlock x:Name="txtSpeed"
                           Text="&#x2191;&#x2193; 0 B/s"
                           FontSize="11"
                           Foreground="#B0B0B0"
                           VerticalAlignment="Center"
                           ToolTip="Current network upload/download speed"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
