<UserControl
    x:Class="DataRippleAIDesktop.HelperControls.RoundedButtonWithImageCustomized"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="267"
    Height="66"
    mc:Ignorable="d">
    <Grid x:Name="ContentGrid" Margin="6,3,3,6">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="0*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Button
            Height="53"
            Margin="1,0,1,0"
            VerticalAlignment="Center"
            Click="Button_Click"
            Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
            FontFamily="Microsoft YaHei UI"
            FontWeight="Bold"
            Foreground="White" Grid.Column="1">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Background" Value="#4169E1" />
                    <Setter Property="BorderBrush" Value="Gray" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="Black" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>

            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        Margin="0,0,0,0"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="2"
                        CornerRadius="25 ">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Button.Template>

            <StackPanel
                Width="210"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <!--  Button Text  -->
                <TextBlock
                    x:Name="ButtonTextBlock"
                    Width="132"
                    Margin="0,0,5,0"
                    VerticalAlignment="Center"
                    FontFamily="Microsoft YaHei UI"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="{Binding ButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <Image
                    x:Name="ButtonImage"
                    Width="80"
                    Height="33"
                    Source="{Binding ImageSource, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
                <!--  Button Image  -->
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
