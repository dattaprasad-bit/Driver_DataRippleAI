<UserControl
    x:Class="DataRippleAIDesktop.HelperControls.BottomBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DataRippleAIDesktop.HelperControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="Auto"
    Height="60"
    mc:Ignorable="d">
    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Orientation="Horizontal">
        <!--  Transcription Button  -->
        <Button x:Name="btnLiveCall"
            Width="72"
            Height="60"
            Margin="10,0"
            HorizontalAlignment="Center"
            Background="Transparent"
            BorderBrush="Transparent">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Style.Triggers>
                        <!--  MouseOver Trigger  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4169E1" />
                            <Setter Property="BorderBrush" Value="#4169E1" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <StackPanel
                Width="67"
                Height="50"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <Image
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Source="/Resources/ImageMic.png"
                    Stretch="UniformToFill" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    FontFamily="Microsoft YaHei UI"
                    FontSize="10"
                    Foreground="#4169E1"
                    Text="LiveCall" />
            </StackPanel>
        </Button>

        <!--  History Button  -->
        <Button x:Name="btnHistory"
            Width="72"
            Height="60"
            Margin="10,0"
            HorizontalAlignment="Center"
            Background="Transparent"
            BorderBrush="Transparent">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4169E1" />
                            <Setter Property="BorderBrush" Value="#4169E1" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <StackPanel
                Width="67"
                Height="50"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <Image
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Source="/Resources/ImageHistory.png"
                    Stretch="UniformToFill" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    FontFamily="Microsoft YaHei UI"
                    FontSize="10"
                    Foreground="#1DB8B8"
                    Text="History" />
            </StackPanel>
        </Button>

        <!--  Connect Button  -->
        <Button x:Name="btnConnect"
            Width="72"
            Height="60"
            Margin="10,0"
            HorizontalAlignment="Center"
            Background="Transparent"
            BorderBrush="Transparent">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#27AE60" />
                            <Setter Property="BorderBrush" Value="#27AE60" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <StackPanel
                Width="67"
                Height="50"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <Image
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Source="/Resources/ImageMic.png"
                    Stretch="UniformToFill" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    FontFamily="Microsoft YaHei UI"
                    FontSize="10"
                    Foreground="#27AE60"
                    Text="Connect" />
            </StackPanel>
        </Button>

        <!--  Disconnect Button  -->
        <Button x:Name="btnDisconnect"
            Width="72"
            Height="60"
            Margin="10,0"
            HorizontalAlignment="Center"
            Background="Transparent"
            BorderBrush="Transparent"
            IsEnabled="False">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E74C3C" />
                            <Setter Property="BorderBrush" Value="#E74C3C" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <StackPanel
                Width="67"
                Height="50"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <Image
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Source="/Resources/ImageLogout.png"
                    Stretch="UniformToFill" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    FontFamily="Microsoft YaHei UI"
                    FontSize="10"
                    Foreground="#E74C3C"
                    Text="Disconnect" />
            </StackPanel>
        </Button>


        <!--  Browser Button  -->
        <Button x:Name="btnLogout"
            Width="72"
            Height="60"
            Margin="10,0"
            HorizontalAlignment="Center"
            Background="Transparent"
            BorderBrush="Transparent">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4169E1" />
                            <Setter Property="BorderBrush" Value="#4169E1" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <StackPanel x:Name="spLogout"
                Width="67"
                Height="50"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <Viewbox Width="30" Height="30"
                         HorizontalAlignment="Center">
                    <Canvas Width="24" Height="24">
                        <Path Data="M17,7l-1.41,1.41L18.17,11H8v2h10.17l-2.58,2.58L17,17l5-5L17,7z M4,5h8V3H4C2.9,3,2,3.9,2,5v14c0,1.1,0.9,2,2,2h8v-2H4V5z"
                              Fill="White" />
                    </Canvas>
                </Viewbox>
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    FontFamily="Microsoft YaHei UI"
                    FontSize="10"
                    Foreground="White"
                    Text="Logout" />
            </StackPanel>
        </Button>
    </StackPanel>
</UserControl>
