<UserControl
    x:Class="DataRippleAIDesktop.HelperControls.RoundedButtonCustomized"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="209"
    Height="50"
    mc:Ignorable="d">
    <Grid x:Name="ContentGrid" Margin="6,3,3,6">

        <Button
            Margin="1,0,3,2"
            Click="Button_Click"
            Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
            FontFamily="Microsoft YaHei UI"
            FontWeight="Bold"
            Foreground="White">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Background" Value="#4169E1" />
                    <Setter Property="BorderBrush" Value="Gray" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="Black" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>

            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        Margin="0,0,0,0"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="2"
                        CornerRadius="25 ">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Button.Template>


            <!--  Button Text  -->
            <TextBlock
                x:Name="ButtonTextBlock"
                Margin="0,0,5,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Microsoft YaHei UI"
                FontWeight="Bold"
                Foreground="White"
                Text="{Binding ButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}" />

        </Button>
    </Grid>
</UserControl>
