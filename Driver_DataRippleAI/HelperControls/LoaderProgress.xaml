<UserControl
    x:Class="DataRippleAIDesktop.HelperControls.LoaderProgress"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DataRippleAIDesktop.HelperControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="185"
    Height="68"
    mc:Ignorable="d">
    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <Style x:Key="BlueIndeterminateProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="30" />
            <Setter Property="Width" Value="200" />
            <Setter Property="IsIndeterminate" Value="True" />
            <Setter Property="Foreground" Value="#4169E1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border
                                Background="{TemplateBinding Background}"
                                BorderBrush="Gray"
                                BorderThickness="2"
                                CornerRadius="20">
                                <Grid>
                                    <Rectangle
                                        Fill="#E3E3E3"
                                        RadiusX="20"
                                        RadiusY="20" />
                                    <Rectangle
                                        x:Name="PART_Indeterminate"
                                        Margin="55,0,55,0"
                                        Fill="#4169E1"
                                        RadiusX="20"
                                        RadiusY="20">
                                        <Rectangle.RenderTransform>
                                            <TranslateTransform x:Name="indeterminateTranslate" X="0" />
                                        </Rectangle.RenderTransform>
                                        <Rectangle.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation
                                                            AutoReverse="True"
                                                            Storyboard.TargetName="indeterminateTranslate"
                                                            Storyboard.TargetProperty="X"
                                                            From="-50"
                                                            To="50"
                                                            Duration="0:0:2" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Rectangle.Triggers>
                                    </Rectangle>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5,0,5,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="12*" />
            <ColumnDefinition Width="25*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="21" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <ProgressBar
            x:Name="Loader"
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Width="171"
            Height="34"
            Margin="2,0,0,0"
            HorizontalAlignment="Left"
            IsIndeterminate="True"
            Style="{StaticResource BlueIndeterminateProgressBar}" />

        <TextBlock
            x:Name="ProgressLabel"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            FontSize="14"
            FontWeight="Bold"
            Foreground="#4169E1"
            Text="Loading..." Width="80" Height="28" Margin="1,0,0,0" Grid.Column="1" />
    </Grid>
</UserControl>
