{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ============================================================================
  // BACKEND AUDIO STREAMING CONFIGURATION
  // ============================================================================
  // Settings for streaming mic and speaker audio to the backend via WebSocket.
  // The backend handles transcription, speaker identification, and AI responses.
  // If WebSocketUrl is omitted, it is derived from Backend:BaseUrl automatically.
  // ============================================================================
  "BackendAudioStreaming": {
    "WebSocketUrl": "",               // Explicit WSS URL (leave empty to derive from Backend:BaseUrl)
    "SampleRate": 16000,              // Audio sample rate in Hz
    "BitDepth": 16,                   // Bits per sample
    "Channels": 1,                    // 1 = mono, 2 = stereo
    "ChunkingIntervalMs": 200,        // Interval between audio chunks in ms
    "MaxReconnectionAttempts": 10,     // Max reconnect attempts before giving up
    "BaseReconnectionDelayMs": 1000,   // Base delay for exponential backoff (ms)
    "PingIntervalSeconds": 30,         // Seconds between health pings
    "PongTimeoutSeconds": 10,          // Seconds to wait for pong before stale
    "ConnectionTimeoutSeconds": 20,    // Seconds to wait for initial connection
    "LogEveryChunk": false             // When true, log every audio chunk at Debug level (for backend debugging)
  },

  // ============================================================================
  // AUDIO DEVICE CONFIGURATION
  // ============================================================================
  // Settings for audio input/output devices
  // These are typically set through the UI and saved automatically
  // ============================================================================
  "AudioDevices": {
    "SelectedMicrophoneDevice": "",  // Name of selected microphone device (empty = default)
    "SelectedSpeakerDevice": "",  // Name of selected speaker/headphone device (empty = default)
    "MicrophoneDeviceIndex": 0,  // Index of microphone device in system device list
    "SpeakerDeviceIndex": 0,  // Index of speaker device in system device list
    "DevModeSystemAudioOnly": false,  // DevMode: Enable system audio capture only (no microphone) - for testing with PC audio playback
    "EnableAudioFormatDiagnostics": true,  // Enable detailed audio format logging
    "LogAudioFormatChanges": true,  // Log when audio format changes are detected
    "VerboseAudioLogging": false  // Enable verbose audio processing logs (can be noisy)
  },

  // ============================================================================
  // CALL LOGGING CONFIGURATION
  // ============================================================================
  // Settings for call logging and recording
  // ============================================================================
  "CallLogging": {
    "EnableCallLogging": false  // Enable/disable call logging to files
  },

  // ============================================================================
  // BACKEND API CONFIGURATION
  // ============================================================================
  // Settings for backend authentication and API communication
  // ============================================================================
  "Backend": {
    "BaseUrl": "https://ghostagent-dev.dataripple.ai/api/",  // Base URL for backend API
    "AuthLoginPath": "/auth/login",  // Path for authentication endpoint
    "RefreshIntervalInMinutes": 15,  // Token refresh interval (minutes)
    "TokenExpirationPeriodInHours": 24  // Token expiration period (hours)
  },

  // ============================================================================
  // CLIENT INTEGRATION CONFIGURATION
  // ============================================================================
  // Settings for frontend WebSocket integration
  // ============================================================================
  "ClientIntegration": {
    "demoFrontWebSocket": "ws://localhost:3006/ws/",  // Frontend WebSocket URL for demo/testing
    "EnableFrontendIntegration": true  // Enable/disable frontend WebSocket integration
  }
}
